@CONFERENCE{Sarabia-Jacome2023,
	author = {Sarabia-Jacome, David and Grasa, Eduard and Catalan, Marisa},
	title = {Fine-Grained Traffic Differentiation in Tactile Internet Scenarios Using RINA},
	year = {2023},
