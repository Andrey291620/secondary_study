@ARTICLE{Cangondo2026,
	author = {Cangondo, Geraldo and Silva, Bruno M.C. and Ladeira, Edgar},
	title = {A weighted reputation-based cooperative model to optimize internet connectivity in intermittent IoT networks},
	year = {2026},
	journal = {Computer Networks},
	volume = {282},
	pages = {},
	doi = {10.1016/j.comnet.2026.112278},
	url = {https://www.scopus.com/pages/publications/105035386968?origin=resultslist},
	affiliations = {Instituto de Telecomunicações, Department of Informatics, University of Beira Interior, Covilhã, 6201-001, Portugal},
	abstract = {Mobile applications and Internet of Things (IoT) solutions increasingly rely on efficient integration with cloud and edge infrastructures to deliver real-time services and maintain high-quality user experiences. However, in many urban and rural environments, IoT applications often face intermittent connectivity, which compromises service reliability and availability. To address this challenge, this work proposes a reputation-based cooperative framework designed to operate over intermittent and challenged networks, leveraging the device-edge-cloud continuum. The proposed mechanism integrates Machine Learning techniques to dynamically assign adaptive weights to both technical and behavioural factors, including Battery, Storage, Interaction Score (I_Score), Delivery Quality (Q_Delivery), and Interaction History (Hist). These factors are aggregated into a dynamic reputation score that guides cooperation decisions among IoT-enabled mobile devices, even under intermittent network conditions. The framework was validated through simulations and a real-world pilot using the Wall by Wall tourism application, integrating device-to-device cooperation with cloud-assisted programmability. Results demonstrate a cooperation rate of 80.4%, a node rejection rate of 19.6%, and an average energy consumption of only 2.14% per interaction, achieving minimal overhead and enhanced energy efficiency. The close alignment between simulated and real-world results confirms the robustness and practical viability of the approach. © 2026 The Author(s)},
