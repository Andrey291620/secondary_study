@ARTICLE{Ji2016,
	author = {Ji, Wen and Chen, Bo-Wei and Wang, Xiangdong and Luo, Haiyong and Kim, Mucheol and Chen, Yiqiang},
	title = {Cross-layer opportunistic scheduling for device-to-device video multicast services},
