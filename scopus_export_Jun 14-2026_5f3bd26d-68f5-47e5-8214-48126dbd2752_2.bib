@CONFERENCE{Liu201760,
	author = {Liu, Yin and Song, Zheng and Tilevich, Eli},
	title = {Querying invisible objects: Supporting data-driven, privacy-preserving distributed applications},
	year = {2017},
	journal = {ACM International Conference Proceeding Series},
	pages = {60 - 72},
	doi = {10.1145/3132190.3132206},
	url = {https://www.scopus.com/pages/publications/85054266519?origin=resultslist},
	affiliations = {Software Innovations Lab., Virginia Tech, United States},
	abstract = {When transferring sensitive data to a non-trusted party, end-users require that the data be kept private. Mobile and IoT application developers want to leverage the sensitive data to provide better user experience and intelligent services. Unfortunately, existing programming abstractions make it impossible to reconcile these two seemingly conflicting objectives. In this paper, we present a novel programming mechanism for distributed managed execution environments that hides sensitive user data, while enabling developers to build powerful and intelligent applications, driven by the properties of the sensitive data. Specifically, the sensitive data is never revealed to clients, being protected by the runtime system. Our abstractions provide declarative and configurable data query interfaces, enforced by a lightweight distributed runtime system. Developers define when and how clients can query the sensitive data's properties (i.e., how long the data remains accessible, how many times its properties can be queried, which data query methods apply, etc.). Based on our evaluation, we argue that integrating our novel mechanism with the Java Virtual Machine (JVM) can address some of the most pertinent privacy problems of IoT and mobile applications. © 2017 ACM.},
	author_keywords = {Data privacy; Data-intensive applications; Programming abstractions; Virtual machine design},
	keywords = {Abstracting; Computer programming; Internet of things; Machine design; Network security; Search engines; Virtual addresses; Virtual machine; Conflicting objectives; Data-intensive application; Distributed applications; Execution environments; Intelligent applications; Java virtual machines; Programming abstractions; Programming mechanism; Data privacy},
	publisher = {Association for Computing Machinery},
	isbn = {978-145035340-3},
	language = {English},
	abbrev_source_title = {ACM Int. Conf. Proc. Ser.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 6; Conference name: 14th International Conference on Managed Languages and Runtimes, ManLang 2017; Conference sponsors: Charles University; Faculty of Mathematics and Physics; Oracle Labs; Conference code: 139444; Conference date: 27 September 2017 through 29 September 2017}
}

@CONFERENCE{Tangudu2025,
	author = {Tangudu, Narendranath Durga and Shah, Sapan Pramodkumar and Seenivasan, Varadarajan and Ambati, Venkata Anil Kumar and Pattan, Basavaraj Jayawant and Yoon, Seungil and Vankayala, Satya Kumar},
	title = {Application Service Monitoring in Cellular IoT Network},
	year = {2025},
	journal = {Proceedings - IEEE Consumer Communications and Networking Conference, CCNC},
	pages = {},
	doi = {10.1109/CCNC54725.2025.10976218},
	url = {https://www.scopus.com/pages/publications/105005147279?origin=resultslist},
	affiliations = {Samsung R&d Institute, Bangalore, India; Samsung Electronics, Seoul, South Korea},
	abstract = {With 5G a reality, communication is not only getting faster and better, but also the new verticals, which were so far not serviced by the cellular industry, are supported. One of the areas where 5 G has promising impact is enabling the Internet of Things (IoT) communication. With higher spectrum and bandwidth, 5G enables massive number of devices to connect to the IoT networks. At the same time, the exponential growth of the number of connected devices puts unprecedented load on cellular infrastructure. Further, 5G enables IoT applications to control more devices remotely where low latency and high throughput are critical performance criteria - like healthcare and factory applications. For such applications, it is essential that the application service remains available and be responsive always. Continuous monitoring at all the layers is critical in ensuring the seamless and uninterrupted service availability, thus improving the user experience and efficient use of resources. In this paper, the authors explain the benefits of Application Service Monitoring (ASM) in coordination with the underlying transport in providing the best quality of experience for the user through a framework using 3GPP Service Enabler Architecture Layer (SEAL). The paper also provides a mathematical model of the Quality of Service (QoS) adaptation through Network and Vertical Application Layer (VAL) coordination feature of framework and substantiate the same with the simulation and its results. The paper finally provides simulation results explaining the benefits of using ASM framework with SEAL. © 2025 IEEE.},
