	keywords = {5G mobile communication systems; Analytic hierarchy process; Computer circuits; Fuzzy filters; Fuzzy logic; Heterogeneous networks; Internet of things; Quality of service; Web services; 5g heterogeneous network; Access selection; Access selection algorithms; Fuzzy logic theory; Fuzzy-Logic; Handover frequencies; Multi-services; Relative entropy; Universal access; User-centric; Entropy},
